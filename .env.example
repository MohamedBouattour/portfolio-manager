# Risk: max % of balance per single symbol
MAX_ALLOC_PCT=20

# Bybit stock token symbols (linear perpetuals)
# Set to 'ALL' to automatically fetch and scout all available stock tokens dynamically, 
# or specify a comma-separated list of symbols (e.g. AAPLUSDT,TSLAUSDT)
STOCK_SYMBOLS=ALL
