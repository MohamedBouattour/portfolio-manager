API_KEY=api key
SECRET_KEY=secret key
TIME_FRAME=D
BALANCE=10000
LEVERAGE=3
USE_FUTURES=true
FEE_PCT=0.04

# Position management
PROFIT_THRESHOLD_PCT=15
REBUY_THRESHOLD_PCT=15
