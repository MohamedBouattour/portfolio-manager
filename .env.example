# =============================================================================
# Centralized environment variables for all services
# Decrypted from .env.vault via `npx dotenv-vault@latest pull`
# =============================================================================

# ---------------------------------------------------------------------------
# Bybit Connector (@portfolio/bybit-connector)
# ---------------------------------------------------------------------------
API_KEY=api key
SECRET_KEY=secret key

# ---------------------------------------------------------------------------
# Market Scouter (@portfolio/market-scouter)
# ---------------------------------------------------------------------------
TIME_FRAME=240

# ---------------------------------------------------------------------------
# BFF (@portfolio/bff)
# ---------------------------------------------------------------------------
PORT=3000
BYBIT_CONNECTOR_URL=http://localhost:3001
MARKET_SCOUTER_URL=http://localhost:3002
PORTFOLIO_MANAGER_URL=http://localhost:3003

# ---------------------------------------------------------------------------
# Portfolio Manager (@portfolio/portfolio-manager)
# ---------------------------------------------------------------------------
BALANCE=10000
LEVERAGE=3
USE_FUTURES=true
MANUAL_MODE=false
FEE_PCT=0.04

# Position management
PROFIT_THRESHOLD_PCT=15
REBUY_THRESHOLD_PCT=15
POSITION_REDUCE_PCT=15
REDUCE_PCT=15
REBUY_QTY_PCT=15

# Risk: max % of balance per single symbol
MAX_ALLOC_PCT=20

# Stoploss
DRY_RUN=false

# Bybit stock token symbols (linear perpetuals)
STOCK_SYMBOLS=ALL
