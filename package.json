{
  "name": "bybit-monorepo",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "services/bybit-connector",
    "services/market-scouter",
    "services/portfolio-manager",
    "services/bff",
    "services/portfolio-manager-frontend",
    "packages/contracts"
  ],
  "scripts": {
    "build:connector": "npm run build -w @portfolio/bybit-connector",
    "build:scouter": "npm run build -w @portfolio/market-scouter",
    "build:manager": "npm run build -w @portfolio/portfolio-manager",
    "build:bff": "npm run build -w @portfolio/bff",
    "build:frontend": "npm run build -w @monorepo/frontend",
    "build": "npm run build -w @portfolio/contracts && npm run build -w @portfolio/bybit-connector && npm run build -w @portfolio/market-scouter && npm run build -w @portfolio/portfolio-manager && npm run build -w @portfolio/bff && npm run build -w @monorepo/frontend",
    "dev:connector": "npm run dev -w @portfolio/bybit-connector",
    "dev:scouter": "npm run dev -w @portfolio/market-scouter",
    "dev:manager": "npm run dev -w @portfolio/portfolio-manager",
    "dev:bff": "npm run dev -w @portfolio/bff",
    "dev:frontend": "npm run start -w @monorepo/frontend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test -w @monorepo/frontend",
    "coverage": "npm run coverage -w @monorepo/frontend",
    "deploy": "sh scripts/deploy.sh",
    "deploy:win": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
